# ==========================================
# AI Career Copilot Environment Configuration
# ==========================================

# --- General App Configuration ---
APP_NAME="CareerCopilot"
DEBUG=true
HOST="0.0.0.0"
PORT=8000

# --- Database Configurations ---
# Use postgresql+asyncpg for async SQLAlchemy engine
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/careercopilot"

# --- Cache Configurations ---
REDIS_URL="redis://localhost:6379/0"

# --- Third-Party Integration Credentials ---
# Telegram Bot Token (Obtain from @BotFather)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-here"

# Gemini API Key (Obtain from Google AI Studio)
GEMINI_API_KEY="your-gemini-api-key-here"

# --- Observability & Monitoring ---
# LangSmith settings (for LangGraph trace graphs)
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your-langsmith-api-key-here"
LANGCHAIN_PROJECT="career-copilot"

# OpenTelemetry configuration
OTEL_SERVICE_NAME="career-copilot"
# OTLP collector endpoint, e.g., local collector or third-party service
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
